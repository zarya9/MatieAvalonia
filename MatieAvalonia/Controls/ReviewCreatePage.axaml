<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="using:MatieAvalonia.Models"
             x:Class="MatieAvalonia.Controls.ReviewCreatePage"
             MinWidth="400">
  <Grid RowDefinitions="Auto,*" RowSpacing="12">
    <TextBlock Text="Отзыв" FontSize="16" FontWeight="SemiBold" Foreground="Black"/>
    <Border Grid.Row="1" BorderBrush="Black" BorderThickness="1" Padding="16" Background="White" MaxWidth="480" HorizontalAlignment="Left">
      <StackPanel Spacing="10">
        <TextBlock Name="TxtReviewError"
                   IsVisible="False"
                   TextWrapping="Wrap"
                   Foreground="#C00000"
                   FontSize="12"/>
        <TextBlock Text="Услуга" FontSize="12" Foreground="Black"/>
        <ComboBox Name="CmbService"
                  Classes="wireFrameField"
                  PlaceholderText="Выберите услугу"
                  MinHeight="34">
          <ComboBox.ItemTemplate>
            <DataTemplate DataType="models:BookingServicePickItem">
              <TextBlock Text="{Binding Name}"/>
            </DataTemplate>
          </ComboBox.ItemTemplate>
        </ComboBox>
        <TextBlock Text="Мастер (необязательно)" FontSize="12" Foreground="Black"/>
        <ComboBox Name="CmbMaster"
                  Classes="wireFrameField"
                  PlaceholderText="Мастер или «без мастера»"
                  MinHeight="34">
          <ComboBox.ItemTemplate>
            <DataTemplate DataType="models:MasterListItem">
              <TextBlock Text="{Binding Display}"/>
            </DataTemplate>
          </ComboBox.ItemTemplate>
        </ComboBox>
        <TextBlock Text="Оценка (1–5)" FontSize="12" Foreground="Black"/>
        <ComboBox Name="CmbRating" Classes="wireFrameField" PlaceholderText="Оценка" MinHeight="34"/>
        <TextBlock Text="Комментарий" FontSize="12" Foreground="Black"/>
        <TextBox Name="TxtComment"
                 Classes="wireFrameField"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 MinHeight="100"
                 MaxLength="255"
                 Watermark="До 255 символов"/>
        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
          <Button Name="BtnSubmitReview" Classes="wireFrameBtn" Content="Отправить" MinWidth="120" Click="BtnSubmitReview_OnClick"/>
          <Button Name="BtnCancelReview" Classes="wireFrameBtn" Content="Отмена" MinWidth="100" Click="BtnCancelReview_OnClick"/>
        </StackPanel>
      </StackPanel>
    </Border>
  </Grid>
</UserControl>
