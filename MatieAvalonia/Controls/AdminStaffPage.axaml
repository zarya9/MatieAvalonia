<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="using:MatieAvalonia.Models"
             x:Class="MatieAvalonia.Controls.AdminStaffPage"
             MinWidth="400">
  <Grid RowDefinitions="Auto,Auto,Auto,*" RowSpacing="10">
    <TextBlock Text="Администратор — сотрудники (мастера)" FontSize="16" FontWeight="SemiBold" Foreground="Black"/>
    <TextBlock Grid.Row="1"
               Text="Добавление: пользователь без записи мастера получает запись в таблице Master с базовой квалификацией."
               FontSize="11"
               Foreground="#666"
               TextWrapping="Wrap"/>
    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8">
      <ComboBox Name="CmbStaffCandidate"
                Classes="wireFrameField"
                PlaceholderText="Пользователь"
                MinWidth="220"
                MinHeight="34">
        <ComboBox.ItemTemplate>
          <DataTemplate DataType="models:UserPickItem">
            <TextBlock Text="{Binding Display}"/>
          </DataTemplate>
        </ComboBox.ItemTemplate>
      </ComboBox>
      <Button Name="BtnAddMasterStaff" Classes="wireFrameBtn" Content="Назначить мастером" MinWidth="160" Click="BtnAddMasterStaff_OnClick"/>
    </StackPanel>
    <Border Grid.Row="3" BorderBrush="Black" BorderThickness="1" Padding="0" Background="White" MinHeight="120">
      <DataGrid Name="StaffGrid"
                AutoGenerateColumns="False"
                IsReadOnly="True"
                GridLinesVisibility="Horizontal"
                HeadersVisibility="Column"
                CanUserResizeColumns="True"
                CanUserSortColumns="False">
        <DataGrid.Columns>
          <DataGridTextColumn Header="ФИО" Binding="{Binding Fio}" Width="*"/>
          <DataGridTextColumn Header="Логин" Binding="{Binding Login}" Width="120"/>
          <DataGridTextColumn Header="Роль" Binding="{Binding Role}" Width="120"/>
          <DataGridTextColumn Header="Квалификация" Binding="{Binding Qualification}" Width="*"/>
        </DataGrid.Columns>
      </DataGrid>
    </Border>
  </Grid>
</UserControl>
