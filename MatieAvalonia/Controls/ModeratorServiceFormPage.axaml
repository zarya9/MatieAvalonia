<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="using:MatieAvalonia.Models"
             x:Class="MatieAvalonia.Controls.ModeratorServiceFormPage"
             MinWidth="400">
  <Grid RowDefinitions="Auto,*" RowSpacing="12">
    <TextBlock Name="TxtTitle" Text="Услуга — создание" FontSize="16" FontWeight="SemiBold" Foreground="Black"/>
    <ScrollViewer Grid.Row="1">
      <Border BorderBrush="Black" BorderThickness="1" Padding="16" Background="White" MaxWidth="520" HorizontalAlignment="Left">
        <StackPanel Spacing="10">
          <TextBlock Name="TxtFormError"
                     IsVisible="False"
                     TextWrapping="Wrap"
                     Foreground="#C00000"
                     FontSize="12"/>
          <TextBlock Text="Название" FontSize="12" Foreground="Black"/>
          <TextBox Name="TxtName" Classes="wireFrameField" Watermark="До 50 символов" MaxLength="50"/>
          <TextBlock Text="Описание" FontSize="12" Foreground="Black"/>
          <TextBox Name="TxtDescription" Classes="wireFrameField" Watermark="До 50 символов" MaxLength="50"/>
          <TextBlock Text="Цена" FontSize="12" Foreground="Black"/>
          <TextBox Name="TxtPrice" Classes="wireFrameField" Watermark="0,00" MaxLength="12"/>
          <TextBlock Text="Коллекция" FontSize="12" Foreground="Black"/>
          <ComboBox Name="CmbCollection"
                    Classes="wireFrameField"
                    PlaceholderText="Выберите коллекцию"
                    MinHeight="34">
            <ComboBox.ItemTemplate>
              <DataTemplate DataType="models:CollectionListItem">
                <TextBlock Text="{Binding Name}"/>
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>
          <TextBlock Text="Изображение" FontSize="12" Foreground="Black"/>
          <Button Name="BtnPickImage" Classes="wireFrameBtn" Content="Выбрать файл…" HorizontalAlignment="Left" Click="BtnPickImage_OnClick"/>
          <Border BorderBrush="Black" BorderThickness="1" Height="120" Background="#FFF8F8F8">
            <Grid>
              <Image Name="ImgPreview" Stretch="Uniform" IsVisible="False"/>
              <TextBlock Name="TxtPreviewPlaceholder"
                         Text="Предпросмотр"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         Foreground="#666"/>
            </Grid>
          </Border>
          <TextBlock Name="TxtUpdatedAt" Text="Обновлено: —" FontSize="12" Foreground="#666"/>
          <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
            <Button Name="BtnSave" Classes="wireFrameBtn" Content="Сохранить" MinWidth="110" Click="BtnSave_OnClick"/>
            <Button Name="BtnCancel" Classes="wireFrameBtn" Content="Отмена" MinWidth="100" Click="BtnCancel_OnClick"/>
          </StackPanel>
        </StackPanel>
      </Border>
    </ScrollViewer>
  </Grid>
</UserControl>
