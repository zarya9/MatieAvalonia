<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="using:MatieAvalonia.Models"
             x:Class="MatieAvalonia.Controls.BookingCreatePage"
             MinWidth="400">
  <Grid RowDefinitions="Auto,*" RowSpacing="12">
    <TextBlock Text="Запись на услугу" FontSize="16" FontWeight="SemiBold" Foreground="Black"/>
    <Grid Grid.Row="1" RowDefinitions="Auto,Auto,*,Auto" RowSpacing="12">
      <TextBlock Name="TxtBookingError"
                 IsVisible="False"
                 TextWrapping="Wrap"
                 Foreground="#C00000"
                 FontSize="12"/>
      <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="12">
        <StackPanel Spacing="6">
          <TextBlock Text="Услуга" FontWeight="SemiBold" Foreground="Black" FontSize="12"/>
          <ComboBox Name="CmbService"
                    Classes="wireFrameField"
                    PlaceholderText="Выберите услугу"
                    MinHeight="34">
            <ComboBox.ItemTemplate>
              <DataTemplate DataType="models:BookingServicePickItem">
                <TextBlock Text="{Binding Name}"/>
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>
        </StackPanel>
        <StackPanel Grid.Column="1" Spacing="6">
          <TextBlock Text="Мастер" FontWeight="SemiBold" Foreground="Black" FontSize="12"/>
          <ComboBox Name="CmbMaster"
                    Classes="wireFrameField"
                    PlaceholderText="Выберите мастера"
                    MinHeight="34">
            <ComboBox.ItemTemplate>
              <DataTemplate DataType="models:BookingMasterPickItem">
                <TextBlock Text="{Binding Display}"/>
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>
        </StackPanel>
      </Grid>
      <Border Grid.Row="2" BorderBrush="Black" BorderThickness="1" Padding="12" Background="White" MinHeight="120">
        <StackPanel Spacing="10">
          <TextBlock Text="Дата и время визита" FontWeight="SemiBold" Foreground="Black" FontSize="12"/>
          <DatePicker Name="DtVisit"/>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="Время" VerticalAlignment="Center" FontSize="12" Foreground="Black"/>
            <TextBox Name="TxtTime"
                     Classes="wireFrameField"
                     Width="120"
                     Watermark="ЧЧ:ММ"
                     MaxLength="5"
                     Text="10:00"/>
          </StackPanel>
        </StackPanel>
      </Border>
      <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
        <Button Name="BtnCancel" Classes="wireFrameBtn" Content="Отмена" MinWidth="100" Click="BtnCancel_OnClick"/>
        <Button Name="BtnSave" Classes="wireFrameBtn" Content="Записаться" MinWidth="120" Click="BtnSave_OnClick"/>
      </StackPanel>
    </Grid>
  </Grid>
</UserControl>
