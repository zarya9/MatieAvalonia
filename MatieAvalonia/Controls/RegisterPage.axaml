<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MatieAvalonia.Controls.RegisterPage"
             MinWidth="480" MinHeight="400">
  <Border BorderBrush="Black"
          BorderThickness="1"
          Background="White"
          Padding="20">
    <Grid RowDefinitions="Auto,*">
      <TextBlock Text="Регистрация" FontSize="18" FontWeight="SemiBold" Foreground="Black" Margin="0,0,0,12"/>
      <ScrollViewer Grid.Row="1">
        <StackPanel Spacing="10" MaxWidth="420" HorizontalAlignment="Left">
          <TextBlock Text="Фамилия" FontSize="12" Foreground="Black"/>
          <TextBox Name="TxtRegFname" Classes="wireFrameField" Watermark="Фамилия" MaxLength="50"/>
          <TextBlock Text="Имя" FontSize="12" Foreground="Black"/>
          <TextBox Name="TxtRegName" Classes="wireFrameField" Watermark="Имя" MaxLength="50"/>
          <TextBlock Text="Отчество" FontSize="12" Foreground="Black"/>
          <TextBox Name="TxtRegPatronymic" Classes="wireFrameField" Watermark="Отчество" MaxLength="50"/>
          <TextBlock Text="Логин" FontSize="12" Foreground="Black"/>
          <TextBox Name="TxtRegLogin" Classes="wireFrameField" Watermark="Логин" MaxLength="50"/>
          <TextBlock Text="Пароль" FontSize="12" Foreground="Black"/>
          <TextBox Name="TxtRegPassword" Classes="wireFrameField" Watermark="Пароль" PasswordChar="*" MaxLength="50"/>
          <TextBlock Name="TxtRegError"
                     IsVisible="False"
                     TextWrapping="Wrap"
                     Foreground="#C00000"
                     FontSize="12"/>
          <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,16,0,0">
            <Button Name="BtnSubmitRegister" Classes="wireFrameBtn" Content="Зарегистрироваться" MinWidth="160" Click="BtnSubmitRegister_Click"/>
            <Button Name="BtnBack" Classes="wireFrameBtn" Content="Назад" MinWidth="100" Click="BtnBack_Click"/>
          </StackPanel>
        </StackPanel>
      </ScrollViewer>
    </Grid>
  </Border>
</UserControl>
