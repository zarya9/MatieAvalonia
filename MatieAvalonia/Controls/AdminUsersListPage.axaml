<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MatieAvalonia.Controls.AdminUsersListPage"
             MinWidth="400">
  <Grid RowDefinitions="Auto,Auto,*,Auto" RowSpacing="10">
    <TextBlock Text="Администратор — пользователи" FontSize="16" FontWeight="SemiBold" Foreground="Black"/>
    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8">
      <Button Name="BtnSortAsc" Classes="wireFrameBtn" Content="А→Я" MinWidth="56" Click="BtnSortAsc_OnClick"/>
      <Button Name="BtnSortDesc" Classes="wireFrameBtn" Content="Я→А" MinWidth="56" Click="BtnSortDesc_OnClick"/>
    </StackPanel>
    <Border Grid.Row="2" BorderBrush="Black" BorderThickness="1" Padding="0" Background="White" MinHeight="120">
      <DataGrid Name="UsersGrid"
                AutoGenerateColumns="False"
                IsReadOnly="True"
                GridLinesVisibility="Horizontal"
                HeadersVisibility="Column"
                CanUserResizeColumns="True"
                CanUserSortColumns="False"
                DoubleTapped="UsersGrid_OnDoubleTapped">
        <DataGrid.Columns>
          <DataGridTextColumn Header="ID" Binding="{Binding IdUser}" Width="56"/>
          <DataGridTextColumn Header="ФИО" Binding="{Binding Fio}" Width="200"/>
          <DataGridTextColumn Header="Логин" Binding="{Binding Login}" Width="140"/>
          <DataGridTextColumn Header="Роль" Binding="{Binding Role}" Width="140"/>
          <DataGridTextColumn Header="Обновлено" Binding="{Binding UpdatedAt}" Width="140"/>
        </DataGrid.Columns>
      </DataGrid>
    </Border>
    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
      <Button Name="BtnPrevPage" Classes="wireFrameBtn" Content="◀" MinWidth="40" Height="30" Click="BtnPrevPage_OnClick"/>
      <TextBlock Name="TxtPageInfo" Text="—" VerticalAlignment="Center" Foreground="Black" FontSize="12"/>
      <Button Name="BtnNextPage" Classes="wireFrameBtn" Content="▶" MinWidth="40" Height="30" Click="BtnNextPage_OnClick"/>
    </StackPanel>
  </Grid>
</UserControl>
