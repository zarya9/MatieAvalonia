<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MatieAvalonia.Controls.CollectionsPage"
             MinWidth="400">
  <Grid RowDefinitions="Auto,Auto,*,Auto" RowSpacing="12">
    <TextBlock Text="Коллекции и направления" FontSize="16" FontWeight="SemiBold" Foreground="Black"/>
    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8">
      <Button Name="BtnSortAsc" Classes="wireFrameBtn" Content="А→Я" MinWidth="56" Click="BtnSortAsc_OnClick"/>
      <Button Name="BtnSortDesc" Classes="wireFrameBtn" Content="Я→А" MinWidth="56" Click="BtnSortDesc_OnClick"/>
    </StackPanel>
    <Border Grid.Row="2" BorderBrush="Black" BorderThickness="1" Background="White" Padding="0">
      <DataGrid Name="CollectionsGrid"
                AutoGenerateColumns="False"
                IsReadOnly="True"
                GridLinesVisibility="Horizontal"
                HeadersVisibility="Column"
                CanUserResizeColumns="True"
                CanUserSortColumns="False"
                DoubleTapped="CollectionsGrid_OnDoubleTapped">
        <DataGrid.Columns>
          <DataGridTextColumn Header="ID" Binding="{Binding IdCollection}" Width="56"/>
          <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="*"/>
          <DataGridTextColumn Header="Услуг в коллекции" Binding="{Binding ServicesCount}" Width="140"/>
        </DataGrid.Columns>
      </DataGrid>
    </Border>
    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
      <Button Name="BtnPrevPage" Classes="wireFrameBtn" Content="◀" MinWidth="44" Height="32" Click="BtnPrevPage_OnClick"/>
      <TextBlock Name="TxtPageInfo" Text="—" VerticalAlignment="Center" Foreground="Black" FontSize="12"/>
      <Button Name="BtnNextPage" Classes="wireFrameBtn" Content="▶" MinWidth="44" Height="32" Click="BtnNextPage_OnClick"/>
    </StackPanel>
  </Grid>
</UserControl>
